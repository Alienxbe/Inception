# Nom de domaine local utilisé par NGINX et WordPress
DOMAIN_NAME=marykman.42.fr


# Configuration de MariaDB (utilisateur root)
SQL_ROOT_PASSWORD=a

# Configuration de la base de données pour WordPress
SQL_DATABASE=wordpress
SQL_USER=marykman
SQL_PASSWORD=a


# Compte administrateur WordPress (accès complet à l’interface d’administration)
WP_ADMIN_USER=marykman
WP_ADMIN_PASSWORD=a
WP_ADMIN_EMAIL=marykman@student.s19.be

# Utilisateur WordPress secondaire (droits limités, rôle = auteur)
WP_USER=zminhas
WP_USER_PASSWORD=a
WP_USER_EMAIL=zminhas@student.s19.be

# Volumes - Emplacements locaux pour stocker les données de MariaDB et WordPress
SQL_DATA_PATH=/home/marykman/data/mysql
WP_DATA_PATH=/home/marykman/data/wordpress